@article{mariza2023,
  abstract = {<p>Lead-free (Ba0.92Ca0.08) (Ti0.95 Zr0.05) O3 (BCZT) ceramics were prepared by a solid-state route (SSR) using ultra-low synthesis (700 °C/30 min and 700 °C/2 h) and sintering temperatures (from 1150 °C to 1280 °C), due to prior activation and homogenization by attrition milling of the starting high purity raw materials for 6 h before the synthesis and of the calcined powders for 3 h before the sintering. The comparison of the thermal analysis of the mixture of the starting raw materials and the same mixture after 6 h attrition milling allowed to evidence the mechanisms of activation, resulting in a significant decrease of the perovskite formation temperature (from 854 °C down to 582 °C). The secondary phases that limit the functional properties of the ceramic and their evolution with the sintering conditions were analyzed by X-ray diffraction (XRD) and scanning electron microscopy (SEM), which allowed the design of a two-step sintering method to eliminate them. A pure tetragonal BCZT perovskite phase (P4mm, c/a = 1.004) and homogeneous ceramic microstructure was obtained for synthesis at 700 °C for 2 h and sintering with the use of a two-step sintering treatment (900 °C for 3 h and 1280 °C for 6 h). The best electromechanical properties achieved were d33 = 455 pC/N, kp = 35%, Qm = 155.</p>},
  author   = {Marzia Mureddu and José F. Bartolomé and Sonia Lopez-Esteban and Maria Dore and Stefano Enzo and Álvaro García and Sebastiano Garroni and Lorena Pardo},
  doi      = {10.3390/ma16030945},
  issn     = {1996-1944},
  issue    = {3},
  journal  = {Materials},
  month    = {1},
  pages    = {945},
  title    = {Solid State Processing of BCZT Piezoceramics Using Ultra Low Synthesis and Sintering Temperatures},
  volume   = {16},
  year     = {2023}
}
@inbook{TitanatesCEACM91,
  abstract  = {Titanates In the former test, a set of samples (typically six) is subjected to a thermal cycle that is less severe than that required to initiate fracture. The cycle is then repeated for successively increasing temperature intervals until each sample has failed. The average temperature interval to initiate failure is then often quoted as the thermal-shock resistance. For an engineering ceramic , a typical procedure would be to heat specimens in a furnace, quench into cold water and inspect visually after dye penetration. A water quench test can, however, only be used for qualitative purposes because the heat-transfer coefficient between the ceramic and water may vary by at least one order of magnitude for different quenching temperatures, depending on whether cooling is by convection, nucle-ate boiling or film formation. More quantitative data may be obtained by quenching samples into a fluidized sand bath, although the critical temperature interval here would be very much greater than when water is used as the quenching medium. In the standard-cycle test, multiple shocks of a known severity are given to a component, which is examined after each cycle or fixed number of cycles. For example, refractory materials are often quenched into cold air after heating to temperatures above 1000 °C. The test conditions are usually chosen so that they are just below the threshold for failure under a single cycle. Because of the large statistical scatter in the strength of specimens, the number of cycles to induce failure generally varies greatly. 6. Conclusions Thermal shock in ceramics is of very wide significance in most applications involving high temperatures as well as, for example, the cooling of large components immediately after firing. The recent development programs on engineering ceramics for high-temperature engine components have been based largely on silicon nitride and silicon carbide, which both have low coefficients of thermal expansion. Here, failure is usually catastrophic once fracture is initiated. The accent of materials development programs is thus on increasing tensile strength to inhibit fracture initiation. For refractory materials, which are much weaker, catastrophic failure is rarer; the emphasis is on improving the fracture toughness to minimize the amount of cracking.},
  author    = {D. Kolar},
  doi       = {10.1016/B978-0-08-034720-2.50133-7},
  issue     = {8},
  booktitle = {Concise Encyclopedia of Advanced Ceramic Materials},
  pages     = {481-486},
  publisher = {Elsevier},
  title     = {Titanates},
  volume    = {80},
  url       = {https://linkinghub.elsevier.com/retrieve/pii/B9780080347202501337},
  year      = {1991}
}
