@article{Mezheritsky2003,
  abstract  = {The relationships between coefficients of electromechanical coupling (CEMC) of various types of piezoceramic resonator (PR) vibrations are considered. Being constant for a given piezoceramic state, the range of variation of piezoceramics dielectric permittivity from a mechanically "free" condition at relatively low frequencies up to an "overall clamped" condition at high frequencies is determined by a consecutive "clamping", caused by a complex of CEMCs of various particular vibrational modes peculiar to the resonator. As the difference between "free" and "overall clamped" permittivities is always determined by the maximal piezomaterial ki3 coupling coefficient, the difference does not depend on the path that was gone through the low-high frequency range, which includes all the vibrational modes possible for a particular PR. The influence of the piezoelectric and elastic anisotropy of lead-zirconatetitanate (PZT) piezoceramic materials on relative CEMC variations was experimentally investigated.},
  author    = {Alex V. Mezheritsky},
  doi       = {10.1109/TUFFC.2003.1256315},
  issn      = {08853010},
  issue     = {12},
  journal   = {IEEE Transactions on Ultrasonics, Ferroelectrics, and Frequency Control},
  pages     = {1742-1751},
