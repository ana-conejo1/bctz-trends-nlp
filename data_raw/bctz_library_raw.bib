@article{Thong2021,
  abstract  = {Excellent electromechanical properties have been reported in lead-free potassium sodium niobate (KNN)-based piezoelectric ceramics over the past 15 years. However, poor reproducibility of the electromechanical properties of KNN has been a major barrier to industrial development, due to a lack of full understanding of some of the processing aspects. Chemical inhomogeneity is one of the most critical challenges in processing, as the properties of KNN-based ceramics are strongly composition-dependent. In the present study, in-situ temperature-dependent X-ray diffraction and thermogravimetric analysis were employed to investigate the chemical reactions that occur during solid-state synthesis. Chemical homogeneity was found to be sensitive to the competition among reactants during synthesis. The phenomenon can reasonably explain the chemical inhomogeneity in KNN and possibly other lead-free piezoelectric ceramic systems prepared via solid-state synthesis.},
  author    = {Hao Cheng Thong and Alexis Payne and Jia Wang Li and Yue Yu Shan Cheng and Jacob L. Jones and Ke Wang},
  doi       = {10.1016/J.ACTAMAT.2021.116833},
  issn      = {1359-6454},
  journal   = {Acta Materialia},
  keywords  = {Ceramic,Chemical Inhomogeneity,Lead-free,Potassium sodium niobate,Solid-state reaction},
  month     = {6},
  pages     = {116833},
  publisher = {Pergamon},
  title     = {The origin of chemical inhomogeneity in lead-free potassium sodium niobate ceramic: Competitive chemical reaction during solid-state synthesis},
  volume    = {211},
  year      = {2021}
}
