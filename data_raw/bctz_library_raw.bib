@misc{Dong2023,
  abstract  = {BiScO3-PbTiO3 (BS-PT) system has been extensively investigation over two decades since the discovery in 2001 for its high piezoelectric coefficient and high Curie temperature (higher 100 ℃ than Pb(Zr,Ti)O3). However, there has not been a systematic review to summarize those achievements of BS-PT material in recent years. In this review, a comprehensive report was displayed on the basic of the fundamental, progress, and perspective of BS-PT-based material. The discovery principle, performance characterization, phase diagram perfection and key issues of BS-PT ceramics were described carefully. In particularly, the fundamentals and state-of-the-art studies of BS-PT ceramics over years were exhibited from piezoelectric properties, Curie temperature, temperature stability, resistivity, etc. Also, an overview of the development of BS-PT thin film and single crystal were provided. Moreover, this review introduced the potential high temperature applications of BS-PT-based ceramics in transducers, actuators, sensors in brief. Finally, future perspectives are afforded to highlight new and emerging research directions of BS-PT system.},
  author    = {Yazhu Dong and Kai Zou and Ruihong Liang and Zhiyong Zhou},
  doi       = {10.1016/j.pmatsci.2022.101026},
  issn      = {00796425},
