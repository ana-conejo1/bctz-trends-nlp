  pages     = {533-537},
  publisher = {John Wiley \& Sons, Ltd},
  title     = {Synthesis and characterization of sol–gel derived Ba0.85Ca0.15Ti0.9Zr0.1O3−xCuO ceramics},
  volume    = {210},
