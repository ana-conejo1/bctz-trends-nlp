  journal  = {Ceramics International},
  keywords = {Ferroelectricity,Ferromagnetism,Lead-free magnetoelectric composite film,Magnetoelectric coupling},
  pages    = {16624-16631},
  title    = {Multiferroic and magnetoelectric properties of lead-free Ba0.8Sr0.2Ti0.9Zr0.1O3-Ni0.8Zn0.2Fe2O4 composite films with different deposition sequence},
