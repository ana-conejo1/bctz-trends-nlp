@inbook{calenderingCEACM91,
  abstract  = {The solid-state reactions between oxides to form spinels involve solid-state diffusion of metallic ions sometimes accompanied by solid-state or gaseous transport of oxygen (Schmalzried 1974). Again, grain growth and sintering of the product and reactant phases will occur in a mixed-oxide powder compact in addition to the solid-state reaction, these additional processes being more important the higher the temperature. Hence, it is desirable to carry out the reaction at temperatures as low as possible to avoid the need for excessive grinding to liberate the small crystals of product phase that may be desirable in the fabrication of the final ceramic product. However, if the reaction is to proceed to completion at low temperatures , then careful control of particle size and degree of mixing of the components is essential to minimize diffusion distances. Improved mixing and lower calcination temperatures can be obtained by using coprecipitated gels and spray-dried or freeze-dried mixed solutions of salts instead of oxide or oxide-carbonate mixtures. Spray calcination is also possible. See also: Powders: Prefixing; Reaction Sintering; Sintering: An Overview Bibliography Brett Ν Η, MacKenzie Κ J D, Sharp J Η 1970 The thermal decomposition of hydrous layer silicates and their related hydroxides, Q. Rev. Chem. Soc. 24: 185-207 Hey A W, Livey D Τ 1969 Calcination processes in oxides. Proc. Br. Ceram. Soc. 12: 13-31 Linsen B G (ed.) 1970 Physical and Chemical Aspects of Adsorbents and Catalysts. Academic Press, London Livey D T, Wanklyn Β M, Hewitt M, Murray Ρ 1957 The properties of MgO powders prepared by the decomposition of Mg(OH) 2. Trans. Br. Ceram. Soc. 56: 217-36 Schmalzried Η},
  author    = {B.R. Schat},
  doi       = {10.1016/B978-0-08-034720-2.50024-1},
  booktitle = {Concise Encyclopedia of Advanced Ceramic Materials},
  pages     = {51-53},
  publisher = {Elsevier},
  title     = {Calendering},
  url       = {https://linkinghub.elsevier.com/retrieve/pii/B9780080347202500241},
  year      = {1991}
}
