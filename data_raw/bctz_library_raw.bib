@article{Baudn2021,
  abstract  = {Reaction sintering (reactive sintering) is an alternative sintering process in which chemical reaction between the constituents of the green compact and its densification occur during the same thermal treatment. It has long been successfully used in the field of traditional ceramics and it has been developed for technical ceramics since the last quarter of the last century. Main general aspects related to reaction sintering are discussed. The system mullite-zirconia is described as a highly developed model system. Special attention is paid to describe the relationships between the developed microstructures and the behavior of the materials. New techniques used in reaction sintering and applications of reaction sintering for waste recycling are also addressed.},
  author    = {Carmen Baudín},
  doi       = {10.1016/B978-0-12-803581-8.11766-7},
  isbn      = {9780128185421},
  journal   = {Encyclopedia of Materials: Technical Ceramics and Glasses: Volume 1-3},
  keywords  = {Composites,Hot presssing,Liquid state reactions,Microstructure,Microwave,Mullite,Oxides,Recycling,Refractories,SPS,Sintering,Solid state reactions,Technical ceramics,Traditional ceramics,Transitory liquid,Zirconia},
  month     = {1},
  pages     = {V1-278-V1-285},
  publisher = {Elsevier},
