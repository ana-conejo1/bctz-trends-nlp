  author = {Sharma Sarita and Thakur Shilpa and Shah J. and Kotnala R.K. and Negi N.S.},
  title  = {Influence of phase dominance on structural, magneto-dielectric, magnetic-electric properties of (Ba0.85Ca0.15Zr0.1Ti0.9)O3-CoFe2O3 composites _ Enhanced Reader},
