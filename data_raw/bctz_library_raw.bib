  publisher = {Institute of Electrical and Electronics Engineers Inc.},
  title     = {Invariants of Electromechanical Coupling Coefficients in Piezoceramics},
  volume    = {50},
  url       = {https://ieeexplore.ieee.org/document/1256315/figures#figures},
  year      = {2003}
}
