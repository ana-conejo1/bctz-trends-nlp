@article{Sayagus2024,
  abstract  = {Different stoichiometries of lead-free BaZr0.2Ti0.8O3–Ba0.7Ca0.3TiO3 (BCZT) prepared by mechanosynthesis and sintered by either conventional sintering (CS) or hot pressing (HP) techniques were studied to establish the dependence of piezoelectric and dielectric properties on sintering parameters and microstructure. All synthesized stoichiometries showed a pseudocubic perovskite phase with homogeneously distributed A- and B-cations in the structure. The BCZT retained the pseudocubic symmetry after sintering and an average grain size <1.8 µm was obtained in all cases. HP sintering hindered the secondary phase segregation observed in the CS ceramics and increased the relative density. Piezoelectric coefficients (d33) ranging from 5.1 to 21 pC/N and from 10.0 to 88.0 pC/N were obtained for CS and HP ceramics, respectively, despite the pseudocubic symmetry and the fine grain size. The higher d33 values for the HP ceramics are a consequence of the higher density, better chemical homogeneity and lower sintering temperature and time required for the mechanosynthesized BCZT powders with high sintering activity.},
  author    = {M. J. Sayagués and A. Otero and L. Santiago-Andrades and R. Poyato and M. Monzón and R. Paz and F. J. Gotor and R. Moriche},
  doi       = {10.1016/J.JALLCOM.2024.176453},
  issn      = {0925-8388},
  journal   = {Journal of Alloys and Compounds},
  keywords  = {BCZT,Dielectric properties,Lead-free piezoceramics,Mechanosynthesis,Piezoelectric properties},
  month     = {12},
  pages     = {176453},
  publisher = {Elsevier},
  title     = {Fine-grained BCZT piezoelectric ceramics by combining high-energy mechanochemical synthesis and hot-press sintering},
  volume    = {1007},
  url       = {https://www.sciencedirect.com/science/article/pii/S0925838824030408},
  year      = {2024}
}
@article{Yan2020,
  abstract  = {Grain size effect is one of the most important issues to develop next-generation multilayer microdevices. In this work, the tetragonal 0.4Ba(Zr0.2Ti0.8)O3–0.6(Ba0.7Ca0.3)TiO3 (BZT–60BCT) ceramics with a wide grain size from 2.1 to 24 μm were successfully prepared by using ultrafine nano powder and two-step sintering. The results demonstrate that critical/intermediate grain size of dielectric constant εr and piezoelectric constant d33 appears at ∼12.9 μm. It was found that the presence of large lattice tetragonality, and enhanced domain wall motion induced by domain coexistence between submicron and nano size in sample with a grain size of ∼12.9 μm, resulting in the superior dielectric and piezoelectric properties. These findings and analyses of the origin of superior dielectric and piezoelectric properties at intermediate grain size have important practical implications in the design of high-performance piezoelectric ceramics.},
  author    = {Xiaodong Yan and Mupeng Zheng and Yu He and Mankang Zhu and Yudong Hou},
  doi       = {10.1016/j.jeurceramsoc.2020.03.071},
  issn      = {1873619X},
  issue     = {12},
  journal   = {Journal of the European Ceramic Society},
  keywords  = {Domain wall motion,Grain size,Perovskite,Piezoelectric property},
  month     = {9},
  pages     = {3936-3945},
  publisher = {Elsevier Ltd},
  title     = {Origin of superior dielectric and piezoelectric properties in 0.4Ba(Zr0.2Ti0.8)O3–0.6(Ba0.7Ca0.3)TiO3 at intermediate grain sizes},
  volume    = {40},
  year      = {2020}
}
@article{Paulik2026,
  abstract  = {The lead-free piezoceramic (Ba,Ca)(Zr,Ti)O3 system has been a focus of scientific research due to its outstanding electromechanical properties, rivaling those of conventional lead-based materials. However, poor reproducibility and unwanted secondary phases are major obstacles to the further development of these materials. Here, we used thermal analysis and high-temperature in-situ X-ray diffraction to identify the chemical reactions taking place during the solid-state synthesis of Ba0.82Ca0.18Zr0.08Ti0.92O3. We identified the phase formation sequence, discovered novel and formerly unknown intermediate phases, and defined the conditions for secondary phase formation. Strategies for the removal of the main secondary phases, namely CaTiO3 and a polytitanate phase, were proposed. This resulted in an increase of the small-signal piezoelectric coefficient d33 by 28 %. The reaction sequence generated in this study will help to improve the processing conditions for this material system to allow for controlled microstructure engineering and enhanced electromechanical properties.},
  author    = {Anna M. Paulik and Sylvia Kunz and Marc Widenmeyer and Oliver Clemens and Anke Weidenkaff and Jurij Koruza},
  doi       = {10.1016/j.jeurceramsoc.2025.117736},
  issn      = {1873619X},
  issue     = {1},
  journal   = {Journal of the European Ceramic Society},
  keywords  = {BCZT,In-situ X-ray diffraction,Lead-free piezoelectrics,Solid-state formation reactions,Solid-state synthesis},
  month     = {1},
  note      = {En el artículo de Amorín et. al. se identificaron las fases presentes como óxido de zirconio monoclínico. Pero aqui no aparece nada sobre el óxido de zirocnio monoclínico. ¿Refinaron estos difractogramas incluso },
  publisher = {Elsevier Ltd},
  title     = {Solid-state formation reactions of Ba0.82Ca0.18Zr0.08Ti0.92O3 piezoceramics},
  volume    = {46},
  year      = {2026}
}
@article{Sun2010,
  abstract  = {An innovative method is presented to estimate the size effect on the ferroelectric phase transitions in the barium titanate ceramic system. The method is based on the phenomenological thermodynamic theory with additional stress led by surface bond contraction. Two symmetry-breaking factors are introduced to correct the stress. This method has enabled us to predict the changing trends in phase transitions and the critical grain size for the disappearance of ferroelectric phase, which is beyond the prediction of existing models. © 2010 The American Ceramic Society.},
